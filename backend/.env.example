# Database (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://eventuser:eventpass@localhost:5432/eventnotifier"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
PORT=3001

# Email (Gmail example — use an App Password, not your account password)
# Go to: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="Event Notifier <your_gmail@gmail.com>"

# Scraping interval in minutes
SCRAPE_INTERVAL_MINUTES=30

# Extension poll interval in minutes (used by Chrome extension)
POLL_INTERVAL_MINUTES=5
