// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  location    String
  city        String?  // Inferred city from location (e.g., "Bangalore", "Mumbai", "Online")
  source      String   // e.g., 'Devfolio', 'Meetup', 'Luma', 'Devpost'
  link        String   @unique
  tags        String[]
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([source])
  @@index([city])
  @@index([createdAt])
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  city        String?  // User's preferred city for event notifications
  preferences Json?    // { notifyEmail: true, tags: ["hackathon", "ai"] }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
}
